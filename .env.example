# Copie ce fichier en ".env" en local, ou configure ces variables
# directement dans l'onglet "Variables" de ton service Railway.
# NE JAMAIS commit le fichier .env réel sur GitHub.

# Token du bot Discord (Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=ton_token_discord_ici

# Clé API Groq (gratuite, sans carte bancaire requise) - https://console.groq.com/keys
GROQ_API_KEY=ta_cle_api_groq_ici

# ID de l'application Discord (Developer Portal > General Information > Application ID)
CLIENT_ID=ton_client_id_ici

# (Optionnel) ID du serveur Discord pour enregistrer les commandes plus vite
# Laisse vide pour un déploiement global (peut prendre jusqu'à 1h pour apparaître)
GUILD_ID=

# Modèle Groq utilisé (voir https://console.groq.com/docs/models)
GROQ_MODEL=llama-3.3-70b-versatile

# Nombre max de messages d'historique gardés en mémoire par salon
MAX_HISTORY=12
